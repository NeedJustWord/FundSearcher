<Window x:Class="FundSearcher.Shell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:consts="clr-namespace:FundSearcher.Consts"
        prism:ViewModelLocator.AutoWireViewModel="True"
        mc:Ignorable="d"
        WindowState="Maximized"
        Title="{Binding Title}" Height="450" Width="800">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <prism:InvokeCommandAction Command="{Binding LoadedCommand}" />
        </i:EventTrigger>
        <i:EventTrigger EventName="Closing">
            <prism:InvokeCommandAction Command="{Binding ClosingCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="基金" Style="{StaticResource MainMenuItem}"
                      Command="{Binding DictCommand}" CommandParameter="{x:Static consts:CommandName.FundMenu}"/>
            <MenuItem Header="指数" Style="{StaticResource MainMenuItem}"
                      Command="{Binding DictCommand}" CommandParameter="{x:Static consts:CommandName.IndexMenu}"/>
            <MenuItem Header="设置" Style="{StaticResource MainMenuItem}"
                      Command="{Binding DictCommand}" CommandParameter="{x:Static consts:CommandName.SettingsMenu}"/>
        </Menu>

        <ContentControl Grid.Row="1" prism:RegionManager.RegionName="{x:Static consts:RegionName.Shell}"/>

        <Grid Grid.Row="2" Margin="3 0 3 3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40*"/>
                <ColumnDefinition Width="20*"/>
                <ColumnDefinition Width="15*"/>
                <ColumnDefinition Width="25*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="{Binding Message}" Style="{StaticResource StatusMessageLabel}"/>

            <Label Grid.Column="1" Content="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageLabel}">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                        <prism:InvokeCommandAction Command="{Binding DictCommand}" CommandParameter="{x:Static consts:CommandName.Copy}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </Label>

            <ProgressBar Grid.Column="3" Value="{Binding Current}" Maximum="{Binding Total}" Style="{StaticResource StatusCrawlingProgress}"/>
            <Label Grid.Column="3" Style="{StaticResource StatusProgressLabel}">
                <Label.Content>
                    <MultiBinding Converter="{StaticResource ValueToPercentConverter}">
                        <Binding Path="Current"/>
                        <Binding Path="Total"/>
                    </MultiBinding>
                </Label.Content>
            </Label>
        </Grid>
    </Grid>
</Window>
