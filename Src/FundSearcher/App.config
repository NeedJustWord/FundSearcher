<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
    </startup>
    <appSettings>
        <!--关注指数-->
        <add key="StarIndexes" value="000300,399006,AU9999,IBOX,NDX100"/>
        <!--持仓基金-->
        <add key="HoldingFunds" value="000834,001021,007538,007664,008701,016532,019547"/>
        <!--黑名单基金-->
        <add key="BlackFunds" value=""/>
        <!--是否缓存页面源代码,1是,0否-->
        <add key="CachePageSource" value="1"/>
        <!--页面源代码缓存过期天数-->
        <add key="CacheOverDay" value="0"/>
        <!--基金信息过期天数-->
        <add key="FundOverDay" value="7"/>
    </appSettings>
</configuration>
